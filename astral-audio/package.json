{
  "name": "astral-audio",
  "displayName": "astral-audio",
  "description": "some useful commands for music production within my daily tool",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "astral-audio.convertWavToMp3",
        "title": "Convert WAV to MP3",
        "category": "Astral Audio"
      },
      {
        "command": "astral-audio.convertDirToMp3",
        "title": "Convert WAV in directory to MP3",
        "category": "Astral Audio"
      },
      {
        "command": "astral-audio.timeStretchAudio",
        "title": "Time Stretch Audio file",
        "category": "Astral Audio"
      },
      {
        "command": "astral-audio.normalizeAudio",
        "title": "Normalize Audio file",
        "category": "Astral Audio"
      },
      {
        "command": "astral-audio.detectBPM",
        "title": "Detect BPM of Audio file",
        "category": "Astral Audio"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "astral-audio.convertWavToMp3",
          "when": "resourceExtname =~ /\\.wav$/i"
        },
        {
          "command": "astral-audio.convertDirToMp3",
          "when": "explorerResourceIsFolder"
        },
        {
          "command": "astral-audio.timeStretchAudio",
          "when": "resourceExtname =~ /\\.(wav|mp3)$/i"
        },
        {
          "command": "astral-audio.normalizeAudio",
          "when": "resourceExtname =~ /\\.(wav|mp3)$/i"
        },
        {
          "command": "astral-audio.detectBPM",
          "when": "resourceExtname =~ /\\.(wav|mp3)$/i"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "package": "vsce package",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}